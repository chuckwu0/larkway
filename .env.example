# 飞书自建应用 App ID(开发者后台获取)
FEISHU_APPID=your_app_id
# 飞书自建应用 App Secret
FEISHU_APPSECRET=your_app_secret
# GitLab 个人或机器账号 PAT(scope: api / write_repository)
GITLAB_TOKEN=your_gitlab_token
# 飞书 bot 的 open_id(bot 加群后从 im.message.receive_v1 事件 mentions[] 里取一次)
LARK_BOT_OPEN_ID=ou_xxx
# 允许 bot 响应的群 chat_id 列表,逗号分隔
LARK_ALLOWED_CHAT_IDS=oc_xxx,oc_yyy
